    "NSAudioCaptureUsageDescription" : {
      "comment" : "Permission string shown when SonicDroplet requests audio capture access.",
      "extractionState" : "stale",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "يحتاج SonicDroplet إلى إذن التقاط الصوت لتسجيل الصوت الذي يتم تشغيله على Mac. تبقى التسجيلات على جهازك ولا يتم رفعها أبدًا."
          }
        },
        "ca" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "SonicDroplet necessita permís de captura d'àudio per gravar el so que es reprodueix al Mac. Els enregistraments es queden al dispositiu i no es pugen mai."
          }
        },
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "SonicDroplet potřebuje oprávnění k zachytávání zvuku, aby mohl nahrávat zvuk přehrávaný na Macu. Nahrávky zůstávají ve vašem zařízení a nikdy se neodesílají."
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "SonicDroplet har brug for tilladelse til lydoptagelse for at kunne optage lyden, der afspilles på din Mac. Optagelserne bliver på din enhed og uploades aldrig."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "SonicDroplet benötigt die Berechtigung zur Audioaufnahme, um den Ton auf deinem Mac aufzuzeichnen. Aufnahmen bleiben auf deinem Gerät und werden niemals hochgeladen."
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Το SonicDroplet χρειάζεται άδεια λήψης ήχου για να εγγράψει τον ήχο που αναπαράγεται στο Mac σας. Οι εγγραφές παραμένουν στη συσκευή σας και δεν αποστέλλονται ποτέ."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "SonicDroplet needs audio capture permission to record the sound playing on your Mac. Recordings stay on your device and are never uploaded."
          }
        },
        "en-AU" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "SonicDroplet needs audio capture permission to record the sound playing on your Mac. Recordings stay on your device and are never uploaded."
          }
        },
        "en-CA" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "SonicDroplet needs audio capture permission to record the sound playing on your Mac. Recordings stay on your device and are never uploaded."
          }
        },
        "en-GB" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "SonicDroplet needs audio capture permission to record the sound playing on your Mac. Recordings stay on your device and are never uploaded."
          }
        },
        "es-ES" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "SonicDroplet necesita permiso de captura de audio para grabar el sonido que se reproduce en tu Mac. Las grabaciones permanecen en tu dispositivo y nunca se suben."
          }
        },
        "es-MX" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "SonicDroplet necesita permiso de captura de audio para grabar el sonido que se reproduce en tu Mac. Las grabaciones permanecen en tu dispositivo y nunca se suben."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "SonicDroplet tarvitsee äänenkaappausluvan tallentaakseen Macillasi toistettavan äänen. Tallenteet pysyvät laitteellasi eikä niitä koskaan ladata verkkoon."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "SonicDroplet a besoin de l’autorisation de capture audio pour enregistrer le son lu sur votre Mac. Les enregistrements restent sur votre appareil et ne sont jamais envoyés."
          }
        },
        "fr-CA" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "SonicDroplet a besoin de l’autorisation de capture audio pour enregistrer le son lu sur votre Mac. Les enregistrements restent sur votre appareil et ne sont jamais téléversés."
          }
        },
        "he" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "SonicDroplet זקוקה להרשאת לכידת שמע כדי להקליט את השמע שמתנגן ב-Mac שלך. ההקלטות נשארות במכשיר שלך ולעולם אינן מועלות."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "आपके Mac पर चल रही आवाज़ रिकॉर्ड करने के लिए SonicDroplet को ऑडियो कैप्चर अनुमति चाहिए। रिकॉर्डिंग आपके डिवाइस पर ही रहती हैं और कभी अपलोड नहीं की जातीं।"
          }
        },
        "hr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "SonicDroplet treba dopuštenje za snimanje zvuka kako bi zabilježio zvuk koji se reproducira na Macu. Snimke ostaju na vašem uređaju i nikada se ne prenose."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Az SonicDropletnak hangrögzítési engedélyre van szüksége ahhoz, hogy felvegye a Macjén lejátszott hangot. A felvételek az eszközén maradnak, és soha nem kerülnek feltöltésre."
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "SonicDroplet memerlukan izin pengambilan audio untuk merekam suara yang diputar di Mac Anda. Rekaman tetap ada di perangkat Anda dan tidak pernah diunggah."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "SonicDroplet richiede l’autorizzazione alla cattura audio per registrare il suono riprodotto sul tuo Mac. Le registrazioni restano sul tuo dispositivo e non vengono mai caricate."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "SonicDroplet は Mac で再生中の音声を録音するためにオーディオキャプチャの許可を必要とします。録音はデバイス上にのみ保存され、アップロードされることはありません。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "SonicDroplet은 Mac에서 재생 중인 소리를 녹음하기 위해 오디오 캡처 권한이 필요합니다. 녹음 파일은 기기에만 저장되며 절대 업로드되지 않습니다."
          }
        },
        "ms" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "SonicDroplet memerlukan kebenaran tangkapan audio untuk merakam bunyi yang dimainkan pada Mac anda. Rakaman kekal pada peranti anda dan tidak pernah dimuat naik."
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "SonicDroplet trenger tillatelse til lydopptak for å kunne ta opp lyden som spilles av på Macen. Opptakene blir liggende på enheten din og lastes aldri opp."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "SonicDroplet heeft toestemming voor audio-opname nodig om het geluid op je Mac op te nemen. Opnamen blijven op je apparaat en worden nooit geüpload."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "SonicDroplet wymaga uprawnienia do przechwytywania dźwięku, aby nagrać dźwięk odtwarzany na Macu. Nagrania pozostają na urządzeniu i nigdy nie są przesyłane."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "O SonicDroplet precisa de permissão de captura de áudio para gravar o som reproduzido no seu Mac. As gravações ficam no seu dispositivo e nunca são enviadas."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "O SonicDroplet precisa de permissão de captação de áudio para gravar o som reproduzido no seu Mac. As gravações permanecem no seu dispositivo e nunca são enviadas."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "SonicDroplet are nevoie de permisiunea de captură audio pentru a înregistra sunetul redat pe Mac-ul tău. Înregistrările rămân pe dispozitivul tău și nu sunt încărcate niciodată."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "SonicDroplet требуется разрешение на захват аудио, чтобы записывать звук, воспроизводимый на вашем Mac. Записи остаются на вашем устройстве и никогда не загружаются."
          }
        },
        "sk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "SonicDroplet potrebuje povolenie na zachytávanie zvuku, aby mohol nahrávať zvuk prehrávaný na vašom Macu. Nahrávky zostávajú vo vašom zariadení a nikdy sa neodosielajú."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "SonicDroplet behöver behörighet för ljudinspelning för att spela in ljudet som spelas på din Mac. Inspelningar stannar på din enhet och laddas aldrig upp."
          }
        },
        "th" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "SonicDroplet ต้องใช้สิทธิ์จับเสียงเพื่อบันทึกเสียงที่กำลังเล่นบน Mac ของคุณ ไฟล์บันทึกจะอยู่บนอุปกรณ์ของคุณและจะไม่ถูกอัปโหลด"
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "SonicDroplet, Mac'inizde çalan sesi kaydetmek için ses yakalama iznine ihtiyaç duyar. Kayıtlar aygıtınızda kalır ve asla yüklenmez."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "SonicDroplet потрібен дозвіл на захоплення аудіо, щоб записувати звук, який відтворюється на вашому Mac. Записи залишаються на вашому пристрої та ніколи не завантажуються."
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "SonicDroplet cần quyền thu âm thanh để ghi lại âm thanh đang phát trên máy Mac của bạn. Bản ghi được giữ trên thiết bị của bạn và không bao giờ được tải lên."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "SonicDroplet 需要音频捕捉权限来录制 Mac 上正在播放的声音。录音会保留在你的设备上，绝不会上传。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "SonicDroplet 需要音訊擷取權限來錄製 Mac 上正在播放的聲音。錄音會保留在你的裝置上，絕不會上傳。"
          }
        }
      }
    },
