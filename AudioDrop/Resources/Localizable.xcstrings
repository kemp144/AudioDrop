    "Local-only. Choose where to save after you stop recording." : {
      "comment" : "A footer text below the source options, explaining that the recording is only available locally.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "محلي فقط. اختر مكان الحفظ بعد إيقاف التسجيل."
          }
        },
        "ca" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Només local. Tria on desar després d'aturar l'enregistrament."
          }
        },
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pouze lokálně. Po zastavení nahrávání zvolte, kam soubor uložit."
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Kun lokalt. Vælg, hvor optagelsen skal gemmes, når du stopper."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nur lokal. Wähle nach dem Stoppen, wo die Aufnahme gespeichert werden soll."
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Μόνο τοπικά. Επιλέξτε πού θα αποθηκευτεί αφού σταματήσετε την εγγραφή."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Local-only. Choose where to save after you stop recording."
          }
        },
        "en-AU" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Local-only. Choose where to save after you stop recording."
          }
        },
        "en-CA" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Local-only. Choose where to save after you stop recording."
          }
        },
        "en-GB" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Local-only. Choose where to save after you stop recording."
          }
        },
        "es-ES" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Solo local. Elige dónde guardar después de detener la grabación."
          }
        },
        "es-MX" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Solo local. Elige dónde guardar después de detener la grabación."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vain paikallisesti. Valitse tallennuspaikka, kun lopetat tallennuksen."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Uniquement en local. Choisissez où enregistrer après l’arrêt."
          }
        },
        "fr-CA" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Enregistrement local seulement. Choisissez où enregistrer après l’arrêt."
          }
        },
        "he" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "מקומי בלבד. בחר היכן לשמור לאחר שתעצור את ההקלטה."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "सिर्फ स्थानीय रूप से। रिकॉर्डिंग रोकने के बाद कहाँ सेव करना है चुनें।"
          }
        },
        "hr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Samo lokalno. Odaberite gdje spremiti nakon zaustavljanja snimanja."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Csak helyben. A felvétel leállítása után válassza ki, hová mentse."
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hanya lokal. Pilih tempat menyimpan setelah Anda menghentikan rekaman."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Solo in locale. Scegli dove salvare dopo aver fermato la registrazione."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ローカル保存のみ。録音を停止した後に保存先を選択します。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "로컬에만 저장됩니다. 녹음을 멈춘 뒤 저장 위치를 선택하세요."
          }
        },
        "ms" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Simpan secara setempat sahaja. Pilih lokasi simpanan selepas anda menghentikan rakaman."
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Kun lokalt. Velg hvor opptaket skal lagres når du stopper."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Alleen lokaal. Kies waar je wilt opslaan nadat je stopt."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tylko lokalnie. Po zatrzymaniu nagrania wybierz miejsce zapisu."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Somente local. Escolha onde salvar depois de parar a gravação."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Apenas local. Escolha onde guardar depois de parar a gravação."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Doar local. Alege unde să salvezi după ce oprești înregistrarea."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Только локально. После остановки записи выберите место сохранения."
          }
        },
        "sk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Iba lokálne. Po zastavení nahrávania vyberte, kam sa má súbor uložiť."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Endast lokalt. Välj var du vill spara när du stoppar inspelningen."
          }
        },
        "th" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "บันทึกไว้ในเครื่องเท่านั้น เลือกตำแหน่งจัดเก็บหลังจากหยุดบันทึก"
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Yalnızca yerel. Kaydı durdurduktan sonra nereye kaydedileceğini seçin."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Лише локально. Після зупинки запису виберіть, куди зберегти файл."
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Chỉ lưu cục bộ. Chọn nơi lưu sau khi bạn dừng ghi."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
